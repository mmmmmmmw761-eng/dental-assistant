# ─── VAPI ─────────────────────────────────────────────────────────────────────
# Любая строка — задаётся здесь и в настройках ассистента VAPI (Server Secret)
VAPI_SECRET=your-secret-key-here

# Какой профиль бизнеса использовать по умолчанию из папки businesses/
DEFAULT_BUSINESS_ID=demo-salon

# ─── Сервер ───────────────────────────────────────────────────────────────────
# Railway подставляет PORT автоматически — не добавляйте PORT в Railway Variables
PORT=3000

# ─── YClients, если у клиента provider = "yclients" ───────────────────────────
# Эти переменные не нужны для manual-режима.
YCLIENTS_PARTNER_TOKEN=ваш-partner-token
YCLIENTS_USER_TOKEN=ваш-user-token
YCLIENTS_COMPANY_ID=1868124
