# ─── YClients ─────────────────────────────────────────────────────────────────
# Маркетплейс → Настройки аккаунта → API ключ
YCLIENTS_PARTNER_TOKEN=ваш-partner-token

# Маркетплейс → Ваше приложение → Доступ к API → User Token
YCLIENTS_USER_TOKEN=ваш-user-token

# ID филиала клиники (из URL app.yclients.com/company/XXXXXX)
YCLIENTS_COMPANY_ID=1868124

# ─── VAPI ─────────────────────────────────────────────────────────────────────
# Любая строка — задаётся здесь и в настройках ассистента VAPI (Server Secret)
# Обязательный параметр: сервер не запустится без него
VAPI_SECRET=your-secret-key-here

# ─── Сервер ───────────────────────────────────────────────────────────────────
# Railway подставляет PORT автоматически — не добавляйте в Railway Variables
PORT=3000
