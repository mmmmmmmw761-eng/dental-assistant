# ─── Google Service Account ───────────────────────────────────────────────────
# Берётся из JSON-файла сервисного аккаунта (поле "client_email")
GOOGLE_SERVICE_ACCOUNT_EMAIL=dental-bot@your-project.iam.gserviceaccount.com

# Берётся из JSON-файла сервисного аккаунта (поле "private_key")
# Важно: оберните в двойные кавычки, переносы строк замените на \n
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Настройки календаря → "Integrate calendar" → Calendar ID
GOOGLE_CALENDAR_ID=abcdef1234567890@group.calendar.google.com

# ─── VAPI ─────────────────────────────────────────────────────────────────────
# Любая произвольная строка — задаётся здесь и в настройках ассистента VAPI (Server Secret)
# Обязательный параметр: сервер не запустится без него
VAPI_SECRET=your-secret-key-here

# ─── Сервер ───────────────────────────────────────────────────────────────────
# Railway подставляет PORT автоматически — не добавляйте его в Railway Variables
PORT=3000
